{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumina",
  "version": "0.1.1",
  "identifier": "studio.zakaru.lumina",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lumina",
        "width": 1280,
        "height": 832,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "shadow": true,
        "theme": null,
        "dragDropEnabled": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "title": "Lumina",
        "width": 420,
        "height": 300,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost blob:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Photography",
    "shortDescription": "Fast local-first photo library manager.",
    "longDescription": "Lumina is a modern, local-first photo library manager: fast scanning, EXIF indexing, WebP thumbnails, virtualized browsing, timeline, smart albums and instant search."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://zakaru.dev/lumina/updates/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyODE3RjU0MzkyNUUwNTQKUldSVTRDVTVWSCtCd2hwZUtjc1Y1ZWtkaEtMemIyT0swV3JqQUd0V1pHZHZDcG4yUEkwQ2lCZEwK"
    }
  }
}
